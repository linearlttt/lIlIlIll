	local script = Instance.new('LocalScript', OutlastHubFIASMODDED.bSliderFrame_4)

	local Players = game:GetService("Players")
	local UIS = game:GetService("UserInputService")
	local task = task
	
	local player = Players.LocalPlayer
	local mouse = player:GetMouse()
	
	-- SETTINGS
	local MIN_DELAY = 0
	local MAX_DELAY = 1
	local fireRate = 0
	local autoFire = false
	local dragging = false
	
	-- UI ELEMENTS
	local slider = script.Parent
	local slideFrame = slider:FindFirstChild("slideFrame")
	local amountValue = slider:FindFirstChild("amountValue")
	
	local parentFrame = slider.Parent
	local toggleButton = parentFrame.Parent:FindFirstChild("WipButton")
	
	-- =========================
	-- GET REMOTE (NO TOOL CHECK)
	-- =========================
	local function getRemote()
		local character = player.Character
		if character then
			local remote = character:FindFirstChild("RemoteEvent", true)
			if remote then return remote end
		end
	
		local backpack = player:FindFirstChild("Backpack")
		if backpack then
			local remote = backpack:FindFirstChild("RemoteEvent", true)
			if remote then return remote end
		end
	
		return nil
	end
	
	-- =========================
	-- FIND CLOSEST PLAYER
	-- =========================
	local function getClosestPlayer()
		local character = player.Character
		if not character then return nil end
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return nil end
	
		local closestPlayer = nil
		local shortestDistance = math.huge
	
		for _, otherPlayer in ipairs(Players:GetPlayers()) do
			if otherPlayer ~= player and otherPlayer.Character then
				local otherHumanoid = otherPlayer.Character:FindFirstChild("Humanoid")
				local otherRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
				if otherHumanoid and otherHumanoid.Health > 0 and otherRoot then
					local distance = (rootPart.Position - otherRoot.Position).Magnitude
					if distance < shortestDistance then
						shortestDistance = distance
						closestPlayer = otherPlayer
					end
				end
			end
		end
	
		return closestPlayer
	end
	
	-- =========================
	-- SLIDER FUNCTIONALITY
	-- =========================
	local function updateSlider(pos)
		pos = math.clamp(pos, 0, 1)
		if slideFrame then
			slideFrame:TweenSize(
				UDim2.new(pos, 0, 1, 0),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.1,
				true
			)
		end
	
		fireRate = MIN_DELAY + (pos * (MAX_DELAY - MIN_DELAY))
		if amountValue then
			amountValue.Text = string.format("Delay: %.2f", fireRate)
		end
	end
	
	if slider then
		slider.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				local relativeX = math.clamp(mouse.X - slider.AbsolutePosition.X, 0, slider.AbsoluteSize.X)
				updateSlider(relativeX / slider.AbsoluteSize.X)
			end
		end)
	
		slider.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)
	
		UIS.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				local relativeX = math.clamp(mouse.X - slider.AbsolutePosition.X, 0, slider.AbsoluteSize.X)
				updateSlider(relativeX / slider.AbsoluteSize.X)
			end
		end)
	end
	
	updateSlider(0)
	
	-- =========================
	-- HOOK FireServer METHOD
	-- =========================
	if hookmethod then
		local mt = getrawmetatable(game)
		setreadonly(mt, false)
	
		local oldFireServer = mt.__namecall
		hookmethod(mt.__namecall, "FireServer", function(self, ...)
			local args = {...}
	
			-- Only allow firing if autoFire is true and attack type is "Heavy"
			if autoFire and args[2] == "Heavy" then
				return oldFireServer(self, ...)
			end
	
			-- Block other FireServer calls
			return nil
		end)
	end
	
	-- =========================
	-- AUTO FIRE LOOP
	-- =========================
	task.spawn(function()
		while true do
			if autoFire then
				local character = player.Character
				local humanoid = character and character:FindFirstChild("Humanoid")
				local targetPlayer = getClosestPlayer()
	
				if humanoid and humanoid.Health > 0 and targetPlayer and targetPlayer.Character then
					local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
					local targetHumanoid = targetPlayer.Character:FindFirstChild("Humanoid")
	
					if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
						local remote = getRemote()
						if remote then
							-- Now this call is intercepted by hookmethod
							remote:FireServer(targetRoot, "Heavy")
						end
					end
				end
			end
	
			task.wait(fireRate)
		end
	end)
	
	-- =========================
	-- TOGGLE BUTTON
	-- =========================
	if toggleButton then
		toggleButton.MouseButton1Click:Connect(function()
			autoFire = not autoFire
			toggleButton.BackgroundColor3 = autoFire and Color3.fromRGB(51,255,47) or Color3.fromRGB(255,11,0)
		end)
	end
end
