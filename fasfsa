	local UIS = game:GetService("UserInputService")
	
	local player = Players.LocalPlayer
	local mouse = player:GetMouse()
	
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	
	local character, humanoid
	local DEFAULT_SPEED = 9
	local currentSpeed = 9
	local enabled = false
	
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	local function updateCharacter(char)
		character = char
		humanoid = char:WaitForChild("Humanoid")
	end
	
	player.CharacterAdded:Connect(updateCharacter)
	if player.Character then
		updateCharacter(player.Character)
	end
	
	
	local dragging = false
	
	local function updateSlider(pos)
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		local speed = math.floor(pos * 100)
		currentSpeed = speed
		amountValue.Text = tostring(speed)
	
		if enabled and humanoid then
			humanoid.WalkSpeed = currentSpeed
		end
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			local pos = math.clamp((mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local pos = math.clamp((mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	
	local function startSpeedLoop()
		coroutine.wrap(function()
			while enabled do
				if humanoid then
					humanoid.WalkSpeed = currentSpeed
				end
				task.wait(0.05) 
			end
		end)()
	end
	
	
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			enabled = not enabled
	
			if enabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startSpeedLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
				if humanoid then
					humanoid.WalkSpeed = DEFAULT_SPEED
				end
			end
		end)
	end
	
	-- Initial display
	amountValue.Text = tostring(currentSpeed)
end
