local function DSZVA_fake_script() -- OutlastHubFIASMODDED.TargetHit.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubFIASMODDED.TargetHit)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local player = Players.LocalPlayer
	
	local Toggle = false
	local fireRate = 0.2 -- seconds between attacks
	local lastFireTime = 0
	
	local textBox = script.Parent:FindFirstChild("TargetBox")
	local button = script.Parent:FindFirstChild("WipButton")
	local auraConn
	
	local predictionFactor = 0
	local targetHistory = {}
	local MAX_HISTORY = 10 
	
	local function getHRP(char)
		return char and char:FindFirstChild("Torso") or char and char:FindFirstChild("UpperTorso")
	end
	
	local function getRemote()
		local character = player.Character
		if not character then return nil end
	
		local tool = character:FindFirstChild("Fight") or player.Backpack:FindFirstChild("Fight")
		if not tool then return nil end
	
		local localScript = tool:FindFirstChildWhichIsA("LocalScript")
		if not localScript then return nil end
	
		return localScript:FindFirstChild("RemoteEvent")
	end
	
	local function getTargetsFromText(text)
		if not text or text == "" then return {} end
		local targets = {}
		local used = {}
	
		text = text:lower():gsub("^%s+", ""):gsub("%s+$", "")
	
		if text == "all" then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player then
					table.insert(targets, plr)
				end
			end
			return targets
		end
	
		for name in string.gmatch(text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not used[plr] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
					if uname:sub(1, #name) == name or dname:sub(1, #name) == name then
						table.insert(targets, plr)
						used[plr] = true
						break
					end
				end
			end
		end
	
		return targets
	end
	
	local function expandNamesInTextBox()
		if not textBox or textBox.Text == "" then return end
		local newNames = {}
		local used = {}
	
		for name in string.gmatch(textBox.Text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not used[plr] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
					if uname:sub(1, #name) == name or dname:sub(1, #name) == name then
						table.insert(newNames, plr.Name)
						used[plr] = true
						break
					end
				end
			end
		end
	
		if #newNames > 0 then
			textBox.Text = table.concat(newNames, ", ")
		end
	end
	
	
	local function updateTargetHistory(target)
		if not target or not target.Character then return end
		local torso = getHRP(target.Character)
		if not torso then return end
	
		local now = tick()
		local pos = torso.Position
	
		if not targetHistory[target] then
			targetHistory[target] = {positions = {}, velocity = Vector3.new()}
		end
	
		local history = targetHistory[target]
		table.insert(history.positions, {pos = pos, time = now})
		if #history.positions > MAX_HISTORY then
			table.remove(history.positions, 1)
		end
	
		if #history.positions >= 2 then
			local sumVel = Vector3.new()
			local count = 0
			for i = 2, #history.positions do
				local dt = history.positions[i].time - history.positions[i-1].time
				if dt > 0 then
					local v = (history.positions[i].pos - history.positions[i-1].pos)/dt
					if v.Magnitude < 200 then
						sumVel = sumVel + v
						count = count + 1
					end
				end
			end
			if count > 0 then
				history.velocity = sumVel / count
			else
				history.velocity = Vector3.new()
			end
		end
	end
	
	local function getResolvedPosition(target)
		if not target or not target.Character then return nil end
		local torso = getHRP(target.Character)
		if not torso then return torso.Position end
	
		updateTargetHistory(target)
		local history = targetHistory[target]
		if not history then return torso.Position end
	
		return torso.Position + history.velocity * predictionFactor
	end
	
	
	local function startAuraLoop()
		if auraConn then return end
		auraConn = RunService.Heartbeat:Connect(function()
			if not Toggle or not textBox then return end
	
			local char = player.Character
			local hrp = getHRP(char)
			if not hrp then return end
	
			local now = tick()
			local targets = getTargetsFromText(textBox.Text)
	
			for _, target in ipairs(targets) do
				if target and target.Character then
					local targetTorso = getHRP(target.Character)
					local hum = target.Character:FindFirstChildWhichIsA("Humanoid")
					if targetTorso and hum and hum.Health > 0 then
						local resolvedPos = getResolvedPosition(target)
						hrp.CFrame = CFrame.new(resolvedPos)
	
						if now - lastFireTime >= fireRate then
							local remote = getRemote()
							if remote then
								remote:FireServer(targetTorso, "Heavy")
								remote:FireServer(targetTorso, "Combat")
	
								lastFireTime = now
							end
						end
					end
				end
			end
		end)
	end
	
	local function stopAuraLoop()
		if auraConn then
			auraConn:Disconnect()
			auraConn = nil
		end
	end
	
	
	if button then
		button.MouseButton1Click:Connect(function()
			Toggle = not Toggle
			button.BackgroundColor3 = Toggle and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
	
			if Toggle then
				startAuraLoop()
			else
				stopAuraLoop()
			end
		end)
	end
	
	if textBox then
		textBox.FocusLost:Connect(expandNamesInTextBox)
	end
	
	
	player.CharacterAdded:Connect(function()
		if Toggle then
			startAuraLoop()
		end
	end)
end
