local function KDYDB_fake_script() -- OutlastHubFIASMODDED.FarmTarget.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubFIASMODDED.FarmTarget)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local player = Players.LocalPlayer
	
	local Toggle = false
	local textBox = script.Parent:FindFirstChild("TargetBox")
	local button = script.Parent:FindFirstChild("WipButton")
	local auraConn
	
	local ignoreIDs = {
		[10224205063] = true,
		[10246426788] = true
	}
	
	local function getHRP(char)
		return char and char:FindFirstChild("HumanoidRootPart")
	end
	
	local function getTargetsFromText(text)
		if not text or text == "" then return {} end
		local targets = {}
		local used = {}
		text = text:lower():gsub("^%s+", ""):gsub("%s+$", "")
		if text == "all" then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] then
					table.insert(targets, plr)
				end
			end
			return targets
		end
		for name in string.gmatch(text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
					if uname:sub(1, #name) == name or dname:sub(1, #name) == name then
						table.insert(targets, plr)
						used[plr] = true
						break
					end
				end
			end
		end
		return targets
	end
	
	local function expandNamesInTextBox()
		if not textBox or textBox.Text == "" then return end
		local newNames = {}
		local used = {}
		for name in string.gmatch(textBox.Text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
					if uname:sub(1, #name) == name or dname:sub(1, #name) == name then
						table.insert(newNames, plr.Name)
						used[plr] = true
						break
					end
				end
			end
		end
		if #newNames > 0 then
			textBox.Text = table.concat(newNames, ", ")
		end
	end
	
	local function getRemote()
		local tool = workspace:FindFirstChildWhichIsA("Tool") or player.Backpack:FindFirstChild("Fight")
		if not tool then return end
		local localScript = tool:FindFirstChildWhichIsA("LocalScript")
		if not localScript then return end
		return localScript:FindFirstChild("RemoteEvent")
	end
	
	local function bringTarget(target)
		if not target or not target.Character then return end
		local char = player.Character
		if not char then return end
	
		local hrp = getHRP(char)
		local targetHRP = getHRP(target.Character)
		local hum = target.Character:FindFirstChildWhichIsA("Humanoid")
		if not (hrp and targetHRP and hum and hum.Health > 0) then return end
	
		for _, part in ipairs(target.Character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
				part.Anchored = false
			end
		end
	
		local offset = hrp.CFrame.LookVector * 1
		targetHRP.CFrame = CFrame.new(hrp.Position + offset, hrp.Position)
	
		task.delay(0, function()
			for _, part in ipairs(target.Character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
		end)
	
		local remote = getRemote()
		if remote then
			remote:FireServer(targetHRP, "Heavy")
		end
	end
	
	local function startAuraLoop()
		if auraConn then return end
		auraConn = RunService.Stepped:Connect(function()
			if not Toggle or not textBox then return end
			local targets = getTargetsFromText(textBox.Text)
			for _, target in ipairs(targets) do
				bringTarget(target)
			end
		end)
	end
	
	local function stopAuraLoop()
		if auraConn then
			auraConn:Disconnect()
			auraConn = nil
		end
	end
	
	if button then
		button.MouseButton1Click:Connect(function()
			Toggle = not Toggle
			button.BackgroundColor3 = Toggle and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
			if Toggle then
				startAuraLoop()
			else
				stopAuraLoop()
			end
		end)
	end
	
	if textBox then
		textBox.FocusLost:Connect(function()
			expandNamesInTextBox()
		end)
	end
	
	player.CharacterAdded:Connect(function()
		if Toggle then
			startAuraLoop()
		end
	end)
end
