local function BTIS_fake_script() -- MouseClickTouchPlayertoKill.LocalScript 
	local script = Instance.new('LocalScript', MouseClickTouchPlayertoKill)

	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	local UserInputService = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	
	local fireRate = 0.2 -- cooldown between attacks
	local predictionFactor = 0.2
	local targetHistory = {}
	local MAX_HISTORY = 10
	
	local currentTarget = nil
	local lastFireTime = 0
	local enabled = false -- controlled by your WIP button
	
	-- Helper to get torso / HumanoidRootPart
	local function getHRP(char)
		return char and char:FindFirstChild("Torso") or char and char:FindFirstChild("UpperTorso")
	end
	
	-- Get the remote to fire attacks
	local function getRemote()
		local character = player.Character
		if not character then return nil end
	
		local tool = character:FindFirstChild("Fight") or player.Backpack:FindFirstChild("Fight")
		if not tool then return nil end
	
		local localScript = tool:FindFirstChildWhichIsA("LocalScript")
		if not localScript then return nil end
	
		return localScript:FindFirstChild("RemoteEvent")
	end
	
	-- Track target movement for prediction
	local function updateTargetHistory(target)
		if not target or not target.Character then return end
		local torso = getHRP(target.Character)
		if not torso then return end
	
		local now = tick()
		local pos = torso.Position
	
		if not targetHistory[target] then
			targetHistory[target] = {positions = {}, velocity = Vector3.new()}
		end
	
		local history = targetHistory[target]
		table.insert(history.positions, {pos = pos, time = now})
		if #history.positions > MAX_HISTORY then
			table.remove(history.positions, 1)
		end
	
		if #history.positions >= 2 then
			local sumVel = Vector3.new()
			local count = 0
			for i = 2, #history.positions do
				local dt = history.positions[i].time - history.positions[i-1].time
				if dt > 0 then
					local v = (history.positions[i].pos - history.positions[i-1].pos)/dt
					if v.Magnitude < 200 then
						sumVel = sumVel + v
						count = count + 1
					end
				end
			end
			if count > 0 then
				history.velocity = sumVel / count
			else
				history.velocity = Vector3.new()
			end
		end
	end
	
	-- Predict target position
	local function getResolvedPosition(target)
		if not target or not target.Character then return nil end
		local torso = getHRP(target.Character)
		if not torso then return torso.Position end
	
		updateTargetHistory(target)
		local history = targetHistory[target]
		if not history then return torso.Position end
	
		return torso.Position + history.velocity * predictionFactor
	end
	
	-- Instant teleport HRP to target position
	local function teleportToTarget(hrp, targetPos)
		if not hrp then return end
		local clampedPos = Vector3.new(targetPos.X, math.max(targetPos.Y, 5), targetPos.Z)
		hrp.CFrame = CFrame.new(clampedPos)
	end
	
	-- Attack a target once
	local function attackTarget(target)
		if not target or not target.Character then return false end
		local targetTorso = getHRP(target.Character)
		local hum = target.Character:FindFirstChildWhichIsA("Humanoid")
		if not targetTorso or not hum or hum.Health <= 0 then return false end
	
		local now = tick()
		if now - lastFireTime >= fireRate then
			local remote = getRemote()
			if remote then
				remote:FireServer(targetTorso, "Heavy")
				remote:FireServer(targetTorso, "Combat")
				lastFireTime = now
			end
		end
		return true
	end
	
	-- RunService loop: teleport + attack continuously
	RunService.RenderStepped:Connect(function()
		if enabled and currentTarget and currentTarget.Character then
			local hrp = getHRP(player.Character)
			local targetTorso = getHRP(currentTarget.Character)
			local hum = currentTarget.Character:FindFirstChildWhichIsA("Humanoid")
	
			if hrp and targetTorso and hum then
				if hum.Health > 0 then
					local resolvedPos = getResolvedPosition(currentTarget)
					teleportToTarget(hrp, resolvedPos)
					attackTarget(currentTarget)
				else
					currentTarget = nil
				end
			end
		end
	end)
	
	-- Mouse click listener: only works if enabled, detects entire character
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if not enabled then return end
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	
		local mouse = player:GetMouse()
		local target = mouse.Target
		if not target then return end
	
		-- Traverse up the hierarchy to find the player character
		local part = target
		local plr = nil
		while part and part.Parent and part.Parent ~= workspace do
			plr = Players:GetPlayerFromCharacter(part.Parent)
			if plr then break end
			part = part.Parent
		end
	
		if plr and plr ~= player then
			currentTarget = plr
		end
	end)
	-- WIP Button integration
	local parentRoot = script.Parent -- adjust if your button is somewhere else
	local wipButton = parentRoot:FindFirstChild("WipButton")
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			enabled = not enabled
			if enabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
				currentTarget = nil -- stop targeting when disabled
			end
		end)
	end
end
