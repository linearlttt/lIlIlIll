	local ignoreIDs = {
		[10224205063] = true,
		[10246426788] = true
	}
	
	-- =======================
	-- Utilities
	-- =======================
	local function getHRP(char)
		return char and char:FindFirstChild("HumanoidRootPart")
	end
	
	-- =======================
	-- Target Parsing
	-- =======================
	local function getTargetsFromText(text)
		if not text or text == "" then return {} end
		local targets = {}
		local used = {}
	
		text = text:lower():gsub("^%s+", ""):gsub("%s+$", "")
	
		-- If text is "all", target every player except ignored IDs and yourself
		if text == "all" then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] then
					table.insert(targets, plr)
				end
			end
			return targets
		end
	
		-- Otherwise, parse comma-separated names
		for name in string.gmatch(text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
					if uname:sub(1, #name) == name or dname:sub(1, #name) == name then
						table.insert(targets, plr)
						used[plr] = true
						break
					end
				end
			end
		end
	
		return targets
	end
	
	local function expandNamesInTextBox()
		if not textBox or textBox.Text == "" then return end
		local newNames = {}
		local used = {}
	
		for name in string.gmatch(textBox.Text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
					if uname:sub(1, #name) == name or dname:sub(1, #name) == name then
						table.insert(newNames, plr.Name)
						used[plr] = true
						break
					end
				end
			end
		end
	
		if #newNames > 0 then
			textBox.Text = table.concat(newNames, ", ")
		end
	end
	
	-- =======================
	-- Get Remote from Fight tool
	-- =======================
	local function getRemote()
		local character = player.Character
		if not character then return nil end
		local tool = character:FindFirstChild("Fight")
		if not tool then return nil end
		local localScript = tool:FindFirstChildWhichIsA("LocalScript")
		if not localScript then return nil end
	
		return localScript:FindFirstChild("RemoteEvent")
	end
	
	-- =======================
	-- Bring Target Client-Side
	local function bringTarget(target)
		if not target or not target.Character then return end
		local char = player.Character
		if not char then return end
	
		local hrp = getHRP(char)
		local targetHRP = getHRP(target.Character)
		local hum = target.Character:FindFirstChildWhichIsA("Humanoid")
		if not (hrp and targetHRP and hum and hum.Health > 0) then return end
	
		-- Only move if farther than 1 stud
		local distance = (targetHRP.Position - hrp.Position).Magnitude
		if distance > 0.65 then
			-- Temporarily disable collisions so target doesn't push you
			for _, part in ipairs(target.Character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
	
			-- Offset in front of the player based on facing direction
			local offset = hrp.CFrame.LookVector * 0.65 -- 3 studs in front
			targetHRP.CFrame = CFrame.new(hrp.Position + offset, hrp.Position) -- face the player
	
			-- Re-enable collisions after a short delay
			task.delay(0.1, function()
				for _, part in ipairs(target.Character:GetDescendants()) do
					if part:IsA("BasePart") then
						part.CanCollide = true
					end
				end
			end)
		end
	
		-- Fire attacks
		local remote = getRemote()
		if remote then
			remote:FireServer(targetHRP, "Slam")
			remote:FireServer(targetHRP, "Grab")
		end
	end
	-- =======================
	-- Aura Loop
	-- =======================
	local function startAuraLoop()
		if auraConn then return end
		auraConn = RunService.Heartbeat:Connect(function()
			if not Toggle or not textBox then return end
			local targets = getTargetsFromText(textBox.Text)
			for _, target in ipairs(targets) do
				bringTarget(target)
			end
		end)
	end
	
	local function stopAuraLoop()
		if auraConn then
			auraConn:Disconnect()
			auraConn = nil
		end
	end
	
	-- =======================
	-- Toggle Button
	-- =======================
	if button then
		button.MouseButton1Click:Connect(function()
			Toggle = not Toggle
			button.BackgroundColor3 = Toggle and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
	
			if Toggle then
				startAuraLoop()
			else
				stopAuraLoop()
			end
		end)
	end
	
	-- =======================
	-- TextBox Event
	-- =======================
	if textBox then
		textBox.FocusLost:Connect(function()
			expandNamesInTextBox()
		end)
	end
	
	-- =======================
	-- Respawn Handling
	-- =======================
	player.CharacterAdded:Connect(function()
		if Toggle then
			startAuraLoop()
		end
	end)
end
