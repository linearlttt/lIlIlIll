	local function handleCommand(admin, cmd, targetNames, extra)
		if not Admins[admin.UserId] then return end
	
		local targets = {}
		for _, name in ipairs(targetNames or {}) do
			for _, t in ipairs(getTargets(admin, name)) do
				table.insert(targets, t)
			end
