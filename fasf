		warn("TextBox1 or TextBox2 missing")
		return
	end
	
	local Toggle = false
	local ATTACK_INTERVAL = 0.0001 
	
	-- Ignore IDs
	local ignoreIDs = {
		[10220946359] = true,
		[10224205063] = true
	}
	
	
	local function getHRP(char)
		return char and char:FindFirstChild("HumanoidRootPart")
	end
	
	local function getHead(char)
		return char and char:FindFirstChild("Head")
	end
	
	local function getRemote(char)
		local core = char:FindFirstChild("Core")
		if not core then return end
		local comm = core:FindFirstChild("Communicate")
		if not comm then return end
		return comm:FindFirstChild("blank") or comm:FindFirstChildWhichIsA("RemoteEvent")
	end
	
	local function getPlayerByPartial(name)
		name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
		for _, plr in ipairs(Players:GetPlayers()) do
			if not ignoreIDs[plr.UserId] then
				if plr.Name:lower():sub(1, #name) == name
					or plr.DisplayName:lower():sub(1, #name) == name then
					return plr
				end
			end
		end
	end
	
	local function getPlayersFromText(text)
		text = text:lower():gsub("^%s+", ""):gsub("%s+$", "")
	
	
		if text == "all" then
			local list = {}
			for _, plr in ipairs(Players:GetPlayers()) do
				if not ignoreIDs[plr.UserId] then
					table.insert(list, plr)
				end
			end
			return list
		end
	
		-- comma list
		local results, used = {}, {}
		for entry in string.gmatch(text, "([^,]+)") do
			local plr = getPlayerByPartial(entry)
			if plr and not used[plr] then
				results[#results+1] = plr
				used[plr] = true
			end
		end
		return results
	end
	
	
	local function performSwing(attacker, target)
	
		local char = attacker.Character
		if not char then return end
	
		local hrp = getHRP(char)
		local remote = getRemote(char)
		if not hrp or not remote then return end
	
		local tChar = target.Character
		local hum = tChar and tChar:FindFirstChildWhichIsA("Humanoid")
		local head = tChar and getHead(tChar)
	
		if not hum or hum.Health <= 0 or not head then return end
	
		remote:FireServer("Swing")
		remote:FireServer("Attack", {
			Character = char,
			Point = hrp.Position,
			Hit = head,
			Limb = "Head",
			Result = nil
		}, false)
	end
	
	
	local lastAttack = 0
	local function startAttackLoop()
		RunService.Heartbeat:Connect(function(dt)
			if not Toggle then return end
	
			lastAttack = lastAttack + dt
			if lastAttack < ATTACK_INTERVAL then return end
			lastAttack = 0
	
			local attackers = getPlayersFromText(attackerBox.Text)
			local targets   = getPlayersFromText(targetBox.Text)
	
			for _, attacker in ipairs(attackers) do
				for _, target in ipairs(targets) do
					performSwing(attacker, target)
				end
			end
		end)
	end
	
	
	attackerBox.FocusLost:Connect(function(enter)
		if enter and attackerBox.Text:lower() ~= "all" then
			local plr = getPlayerByPartial(attackerBox.Text)
			if plr then attackerBox.Text = plr.Name end
		end
	end)
	
	
	button.MouseButton1Click:Connect(function()
		Toggle = not Toggle
		button.BackgroundColor3 =
			Toggle and Color3.fromRGB(51, 255, 47)
			or Color3.fromRGB(15,15,15)
	
		if Toggle then
			startAttackLoop()
		end
	end)
	
end
coroutine.wrap(DJRTE_fake_script)()
local function VIXZIDT_fake_script() -- AutoJoinParty.LocalScript 
	local script = Instance.new('LocalScript', AutoJoinParty)

	-- =======================
	-- Services
	-- =======================
	local Players = game:GetService("Players")
	local localPlayer = Players.LocalPlayer
	local button = script.Parent
	
	-- =======================
	-- Settings
	-- =======================
	local isToggledOn = false
	local REJOIN_CHECK_INTERVAL = 0.1
	local partyRejoinTask = nil
	
	-- =======================
	-- Functions
	-- =======================
	local function firePartyRemote(eventName, targetPlayer)
		if not targetPlayer or not targetPlayer.Parent then
			return
		end
	
		local communicate = localPlayer:FindFirstChild("Communicate")
		if not communicate then
			warn("Party script: Communicate folder not found on LocalPlayer.")
			return
		end
	
		local interface = communicate:FindFirstChild("Interface")
		if not interface then
			warn("Party script: Interface folder not found under Communicate.")
			return
		end
	
		local remoteEvent = interface:FindFirstChild("RemoteEvent")
		if not remoteEvent or not remoteEvent:IsA("RemoteEvent") then
			warn("Party script: RemoteEvent not found or not a RemoteEvent under Interface.")
			return
		end
	
		local success, err = pcall(function()
			remoteEvent:FireServer(eventName, targetPlayer)
		end)
	
		if not success then
			warn("Error firing party remote (" .. eventName .. " for " .. targetPlayer.Name .. "): " .. tostring(err))
		end
	end
	
	local function startPartyRejoinLoop()
		if partyRejoinTask then
			task.cancel(partyRejoinTask)
			partyRejoinTask = nil
		end
	
		partyRejoinTask = task.spawn(function()
			while isToggledOn do
				for _, pl in ipairs(Players:GetPlayers()) do
					if pl ~= localPlayer and pl.Parent then
						firePartyRemote("AcceptPartyInvite", pl)
					end
				end
				local waitSuccess = pcall(task.wait, REJOIN_CHECK_INTERVAL)
				if not waitSuccess then break end
			end
			partyRejoinTask = nil
		end)
	end
	
	-- =======================
	-- Button Toggle
	-- =======================
	button.MouseButton1Click:Connect(function()
		isToggledOn = not isToggledOn
	
		if isToggledOn then
			button.BackgroundColor3 = Color3.fromRGB(103, 0, 0)
			print("AutoJoinParty: Toggled ON. Inviting to all players' parties.")
			startPartyRejoinLoop()
		else
			button.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
			print("AutoJoinParty: Toggled OFF.")
			if partyRejoinTask then
				task.cancel(partyRejoinTask)
				partyRejoinTask = nil
			end
		end
	end)
end
coroutine.wrap(VIXZIDT_fake_script)()
