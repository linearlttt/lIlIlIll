				end
			end
	
		elseif cmd == "to" then
			local hrp = admin.Character and admin.Character:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			for _, target in ipairs(targets) do
				local thrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
				if thrp then
					hrp.CFrame = thrp.CFrame * CFrame.new(0, 0, 3)
				end
			end
	
		elseif cmd == "loopreset" then
			for _, target in ipairs(targets) do
				local uid = target.UserId
				if LoopReset[uid] then
					LoopReset[uid]:Disconnect()
					LoopReset[uid] = nil
				else
					LoopReset[uid] = target.CharacterAdded:Connect(function(char)
						task.wait(0.1)
						local hum = char:FindFirstChildOfClass("Humanoid")
						if hum then hum.Health = 0 end
					end)
					if target.Character then
						local hum = target.Character:FindFirstChildOfClass("Humanoid")
						if hum then hum.Health = 0 end
					end
				end
			end
	
		elseif cmd == "forcerejoin" then
			for _, target in ipairs(targets) do
				if target ~= admin then
					TeleportService:Teleport(game.PlaceId, target)
	
					if admin  then
						return
					end
				end
			end
	
		elseif cmd == "freeze" then
			for _, target in ipairs(targets) do
				local thrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
				if thrp then thrp.Anchored = true end
			end
	
		elseif cmd == "unfreeze" then
			for _, target in ipairs(targets) do
				local thrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
				if thrp then thrp.Anchored = false end
			end
		end
	end
	
	
