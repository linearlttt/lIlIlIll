	local RunService = game:GetService("RunService")
	local player = Players.LocalPlayer
	
	local Toggle = false
	local textBox = script.Parent:FindFirstChild("TargetBox")
	local button = script.Parent:FindFirstChild("WipButton")
	local auraConn
	
