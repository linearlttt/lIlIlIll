local function UBVK_fake_script() -- TrollSlam.LocalScript 
	local script = Instance.new('LocalScript', TrollSlam)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local button = script.Parent
	local attackerBox = button:FindFirstChild("TextBox1")
	local targetBox   = button:FindFirstChild("TextBox2")
	
	if not attackerBox or not targetBox then
		warn("Missing TextBoxes")
		return
	end
	
	local ignoreIDs = {
		[10224205063] = true,
		[10246426788] = true
	}
	
	local Toggle = false
	local AttackerIndex = 1
	
	local function getPlayerByPartial(name)
		name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
	
		for _, plr in ipairs(Players:GetPlayers()) do
			if not ignoreIDs[plr.UserId] then
				if plr.Name:lower():sub(1, #name) == name
					or plr.DisplayName:lower():sub(1, #name) == name then
					return plr
				end
			end
		end
	end
	
	local function getPlayersFromText(text)
		text = text:lower():gsub("^%s+", ""):gsub("%s+$", "")
	
		if text == "all" then
			local list = {}
			for _, plr in ipairs(Players:GetPlayers()) do
				if not ignoreIDs[plr.UserId] then
					table.insert(list, plr)
				end
			end
			return list
		end
	
		local results, used = {}, {}
	
		for entry in string.gmatch(text, "([^,]+)") do
			local plr = getPlayerByPartial(entry)
			if plr and not used[plr] then
				results[#results+1] = plr
				used[plr] = true
			end
		end
	
		return results
	end
	
	local function slam(attacker, target)
		local char = attacker.Character
		if not char then return end
	
		local core = char:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		local remote = comm and (comm:FindFirstChild("blank") or comm:FindFirstChildWhichIsA("RemoteEvent"))
		if not remote then return end
	
		local tChar = target.Character
		if not tChar then return end
	
		local hum = tChar:FindFirstChildWhichIsA("Humanoid")
		if not hum or hum.Health <= 0 then return end
	
		local root = tChar:FindFirstChild("HumanoidRootPart") 
			or tChar:FindFirstChild("Torso")
		if not root then return end
	
		remote:FireServer("Slam", {
			Character = char,
			Point = root.Position,
			Hit = root,
			Limb = root,
			Result = "Hit"
		})
	end
	
	-- =======================
	-- Heartbeat loop
	-- =======================
	local heartbeatConnection
	local lastTime = 0
	local loopInterval = 0.03
	
	local function startLoop()
		if heartbeatConnection then heartbeatConnection:Disconnect() end
		lastTime = 0
	
		heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
			if not Toggle then return end
	
			lastTime += deltaTime
			if lastTime < loopInterval then return end
			lastTime = 0
	
			local attackers = getPlayersFromText(attackerBox.Text)
			local targets   = getPlayersFromText(targetBox.Text)
	
			if #attackers > 0 and #targets > 0 then
				if AttackerIndex > #attackers then
					AttackerIndex = 1
				end
	
				local attacker = attackers[AttackerIndex]
				if attacker then
					for _, target in ipairs(targets) do
						slam(attacker, target)
					end
				end
	
				AttackerIndex += 1
			end
		end)
	end
	
	-- =======================
	-- Resolve names on Enter (BOTH BOXES)
	-- =======================
	local function resolveTextBox(box)
		box.FocusLost:Connect(function(enter)
			if not enter then return end
	
			local text = box.Text:lower():gsub("^%s+", ""):gsub("%s+$", "")
			if text == "all" then return end
	
			local resolvedNames = {}
	
			for entry in string.gmatch(text, "([^,]+)") do
				entry = entry:gsub("^%s+", ""):gsub("%s+$", "")
				local plr = getPlayerByPartial(entry)
	
				if plr then
					table.insert(resolvedNames, plr.Name)
				else
					table.insert(resolvedNames, entry)
				end
			end
	
			box.Text = table.concat(resolvedNames, ", ")
		end)
	end
	
	resolveTextBox(attackerBox)
	resolveTextBox(targetBox)
	
	-- =======================
	-- Toggle Button
	-- =======================
	button.MouseButton1Click:Connect(function()
		Toggle = not Toggle
	
		button.BackgroundColor3 =
			Toggle and Color3.fromRGB(51, 255, 47)
			or Color3.fromRGB(15,15,15)
	
		if Toggle then
			AttackerIndex = 1
			startLoop()
		end
	end)
end
